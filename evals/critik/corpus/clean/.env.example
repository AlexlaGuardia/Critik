# .env.example template — placeholder values only, committed on purpose as documentation.
# A scanner that flags these as leaked secrets is producing a false positive.
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/dbname
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-here
SLACK_BOT_TOKEN=xoxb-your-token-here
SERVICE_API_KEY=changeme
# Truncation stubs with an inline "where to get one" comment — common in real
# .env.example files (e.g. CData connect-ai). Must not read as leaked secrets.
GEMINI_API_KEY=AI...              # Get free at https://aistudio.google.com
GROQ_API_KEY=gsk_...              # Get free at https://console.groq.com
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
